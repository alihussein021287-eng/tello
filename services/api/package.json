{
  "name": "@tello/api",
  "version": "1.0.0",
  "scripts": {
    "dev":   "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "db:push": "cd ../../packages/db && bunx prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "hono":                 "^4.6.0",
    "hono-rate-limiter":    "^0.4.0",
    "@hono/zod-validator":  "^0.4.0",
    "zod":                  "^3.23.0",
    "jose":                 "^5.9.0",
    "bcryptjs":             "^2.4.3",
    "ioredis":              "^5.4.0",
    "minio":                "^8.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}
